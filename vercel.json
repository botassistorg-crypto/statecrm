{
  "version": 2,
  "routes": [
    {
      "src": "/api/login",
      "dest": "/api/login.js"
    },
    {
      "src": "/api/data",
      "dest": "/api/data.js"
    },
    {
      "src": "/api/save",
      "dest": "/api/save.js"
    },
    {
      "src": "/api/ping",
      "dest": "/api/ping.js"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}
